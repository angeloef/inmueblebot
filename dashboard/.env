# URL base de la API FastAPI.
# El proxy de Vite ya redirige /api/* → http://localhost:8000
# Solo hace falta cambiar esta variable cuando el backend esté en otro host.
VITE_API_BASE_URL=/api

# Admin API key — debe coincidir con ADMIN_API_KEY en el .env del bot.
# Se envía como header x-api-key en todas las llamadas a /admin/*.
VITE_API_TOKEN=your-secure-admin-key-here
