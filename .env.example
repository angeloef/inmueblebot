# =============================================================================
# WhatsApp Business Cloud API (Meta)
# =============================================================================

# Get from Meta Developers Dashboard:
# 1. Go to https://developers.facebook.com/
# 2. Select your WhatsApp Business app
# 3. Go to API Setup > Configuration
# 4. Copy Phone Number ID

# WhatsApp Phone Number ID (from Meta)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Access Token (from Meta API Setup - either temporary or permanent)
WHATSAPP_ACCESS_TOKEN=your_access_token

# Webhook Verify Token - generate a strong random string
# This is what you configure in Meta as "Verify token"
WHATSAPP_WEBHOOK_VERIFY_TOKEN=generate_a_strong_random_string_here

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/inmueblebot

# =============================================================================
# Redis
# =============================================================================
USE_LOCAL_REDIS=false
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=super-secret-change-in-production
ADMIN_API_KEY=your-secure-admin-key-here

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development