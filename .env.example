# =============================================================================
# Google Calendar Integration
# =============================================================================
# Path to the service account JSON credentials file
# Download from Google Cloud Console -> IAM -> Service Accounts -> Keys
GOOGLE_CREDENTIALS_PATH=/app/credentials/google-service-account.json

# Google Calendar ID to use
# Get this from Google Calendar settings -> Integrate calendar -> HTML Link
# Example: abc123@example.com or the calendar email address
GOOGLE_CALENDAR_ID=primary

# =============================================================================
# LLM Configuration - Priority: Gemini 2.5 Flash → OpenRouter → MiniMax
# =============================================================================

# === Primary: Google Gemini 2.5 Flash ===
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# === Backup: OpenRouter ===
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# === Last Resort: MiniMax ===
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_MODEL=minimax/minimax-m2.5:free

# === LLM Settings ===
LLM_TIMEOUT_SECONDS=25
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=1000

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/inmueblebot

# =============================================================================
# Redis
# =============================================================================
USE_LOCAL_REDIS=false
REDIS_URL=redis://redis:6379/0

# =============================================================================
# WhatsApp (Meta)
# =============================================================================
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=super-secret-change-in-prod
ADMIN_API_KEY=your-secure-admin-key

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development