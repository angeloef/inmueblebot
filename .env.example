# =============================================================================
# LLM Configuration
# =============================================================================

# === Primary: Google Gemini 2.5 Flash ===
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# === Backup: OpenRouter ===
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# === Last Resort: MiniMax ===
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_MODEL=minimax/minimax-m2.5:free

# === LLM Settings ===
LLM_TIMEOUT_SECONDS=25
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=1000

# =============================================================================
# WhatsApp Configuration (Meta Cloud API)
# =============================================================================

# Get from Meta Developers Dashboard:
# 1. Go to https://developers.facebook.com/
# 2. Select your WhatsApp Business app
# 3. Go to API Setup > Configuration
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Access Token (from API Setup)
WHATSAPP_ACCESS_TOKEN=your_access_token

# Generate a strong random string for webhook verification
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_secure_verify_token

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/inmueblebot

# =============================================================================
# Redis
# =============================================================================
USE_LOCAL_REDIS=false
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=super-secret-change-in-production
ADMIN_API_KEY=your-secure-admin-key-here

# =============================================================================
# Billing — MercadoPago (Fase 3: suscripción + gating de trial)
# =============================================================================
# Access token de la app de MercadoPago (prod o TEST-... para sandbox).
MERCADOPAGO_ACCESS_TOKEN=
# Secret de la notificación/webhook (Tus integraciones → Webhooks). Sin esto, el
# webhook se RECHAZA en producción (fail-closed). Valida la firma x-signature.
MERCADOPAGO_WEBHOOK_SECRET=
# Precio mensual del plan en ARS. 0 = no configurado → /billing/subscribe da 503.
MP_PLAN_PRICE_ARS=0
# Nombre del plan (campo "reason" del preapproval, visible en MercadoPago).
MP_PLAN_NAME=ViviendApp Mensual
# URL pública de esta API (destino del webhook configurado en MercadoPago).
PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development