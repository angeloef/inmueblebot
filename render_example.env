# ============================================================
# render_example.env — template for local work against Render
# ============================================================
# Copy this to .env (which is gitignored) and fill in values from
# your Render dashboard. Never commit the filled-in .env.
#
# To find each value:
#   DATABASE_URL   → Render dashboard → your Postgres service → "Connect" tab
#                    Use the "External Connection String" (postgresql://...).
#                    The app's resolved_database_url handles the +asyncpg rewrite.
#   OPENAI_API_KEY → platform.openai.com → API keys
#   REDIS_URL      → Render dashboard → your Redis service → "Connect" tab
#                    Use the "External URL" (redis://...).
#   WHATSAPP_*     → Meta for Developers → your WhatsApp Business app
#   ADMIN_API_KEY  → whatever you set in Render env vars for the service
#   GOOGLE_*       → only needed if testing calendar flows locally
#
# Tasks these vars unlock:
#   DATABASE_URL + REDIS_URL + OPENAI_API_KEY
#     → alembic upgrade/stamp, eval harness V2 baseline snapshot,
#       full simulate/ endpoint testing
#   WHATSAPP_* (optional locally)
#     → webhook testing; not needed for migrations or eval
# ============================================================

# ── Postgres (REQUIRED for migrations + eval) ─────────────────
# Paste the External Connection String from Render Postgres "Connect" tab.
# Format:  postgresql://user:password@host/dbname?ssl=require
# The rotated password you set after Phase 0a goes here.
DATABASE_URL=postgresql://inmueblebot_user:ROTATED_PASSWORD@dpg-xxxx-a.oregon-postgres.render.com/inmueblebot_rfv1?ssl=require

# ── Redis (REQUIRED for eval + simulate endpoints) ─────────────
# Paste the External URL from Render Redis "Connect" tab.
REDIS_URL=redis://red-xxxx:6379

# ── OpenAI (REQUIRED for eval harness LLM judge + bot calls) ───
OPENAI_API_KEY=sk-...

# ── Runtime settings (keep these as-is for local dev) ──────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# Controls whether legacy startup DDL runs at boot.
# Keep True until you've verified the baseline migration on a prod clone,
# then set False so Alembic is the sole DDL authority.
RUN_LEGACY_STARTUP_MIGRATION=True

# ── WhatsApp Meta (optional locally) ───────────────────────────
# Only needed if you want to test the real webhook locally.
# Eval harness and alembic work fine without these.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me

# ── Redis memory retry (set 0 locally since Render Redis is not externally reachable)
# 0 = fail-fast → immediate graceful fallback, no 15s wait per chatbot call.
# Leave unset or 3 on Render itself.
MEMORY_REDIS_MAX_RETRIES=0

# ── Admin ───────────────────────────────────────────────────────
ADMIN_API_KEY=dev-admin-key

# ── Google Calendar (optional) ─────────────────────────────────
# Only needed for appointment/calendar testing.
# GOOGLE_TOKEN_JSON=
# GOOGLE_CREDENTIALS_JSON=
