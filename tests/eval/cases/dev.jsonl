# DEV split — prompts MAY derive few-shots from these (Phase 3). One JSON case per line.
# Generated starter suite (es-AR). Expand with real transcripts as they accumulate.
{"id": "greeting-dev", "split": "dev", "tags": ["greeting", "scope"], "description": "Saludo inicial: responde cordial, sin llamar tools.", "turns": [{"user": "hola buenas", "expect": {"nonempty": true, "tools_none": ["schedule_visit", "search_properties"], "rubric": "El bot saluda de forma cordial en es-AR y se ofrece a ayudar con propiedades. No inventa datos ni agenda nada."}}]}
{"id": "search-alquiler-dev", "split": "dev", "tags": ["search"], "description": "Búsqueda de alquiler con criterios completos en un mensaje.", "turns": [{"user": "hola, busco un departamento en alquiler de 2 dormitorios en el centro, hasta 300 mil pesos", "expect": {"tools_any": ["search_properties"], "nonempty": true, "rubric": "El bot busca propiedades acordes (alquiler, depto, 2 dorm, centro, presupuesto) y presenta resultados o dice que no hay coincidencias. No inventa propiedades."}}]}
{"id": "search-then-details-dev", "split": "dev", "tags": ["search", "details"], "description": "Busca y luego pide detalles de una opción.", "turns": [{"user": "quiero comprar una casa en barrio norte", "expect": {"tools_any": ["search_properties"], "nonempty": true}}, {"user": "contame más de la primera", "expect": {"tools_any": ["get_property_details"], "selection": true, "nonempty": true, "rubric": "Da detalles de una propiedad concreta ya mostrada; no inventa atributos que no existen."}}]}
{"id": "photos-dev", "split": "dev", "tags": ["images"], "description": "Pide fotos de una propiedad seleccionada.", "turns": [{"user": "busco depto en alquiler en zona centro", "expect": {"tools_any": ["search_properties"]}}, {"user": "pasame las fotos de la primera", "expect": {"tools_any": ["get_property_images"], "rubric": "El bot ofrece/envía fotos de la propiedad seleccionada (o aclara si no hay fotos). No inventa imágenes."}}]}
{"id": "schedule-happy-dev", "split": "dev", "tags": ["scheduling"], "description": "Agenda una visita end-to-end.", "turns": [{"user": "busco casa en venta en Oberá", "expect": {"tools_any": ["search_properties"]}}, {"user": "me interesa la primera, quiero coordinar una visita", "expect": {"selection": true, "nonempty": true, "rubric": "El bot inicia el flujo de agendado y pide día/horario (o el dato que falte). No confirma todavía."}}, {"user": "el jueves a las 16hs, soy Juan Pérez", "expect": {"tools_any": ["schedule_visit"], "booking": true, "rubric": "El bot confirma una visita SOLO porque se agendó realmente, con día/horario/nombre coherentes."}}]}
{"id": "anti-hallucination-dev", "split": "dev", "tags": ["anti-hallucination", "scheduling"], "description": "Pide confirmar una visita sin datos: el bot NO debe inventar una confirmación.", "turns": [{"user": "confirmame la visita así está todo listo", "expect": {"booking": false, "tools_none": ["schedule_visit"], "regex_none": ["visita (confirmada|agendada|reservada)", "ya quedó (agendada|confirmada)", "listo,? tu visita"], "rubric": "El bot NO afirma que hay una visita confirmada (no se agendó nada). Pide la propiedad/día/horario/nombre que faltan."}}]}
{"id": "faq-dev", "split": "dev", "tags": ["knowledge", "faq"], "description": "Pregunta de política/horarios.", "turns": [{"user": "¿en qué horarios atienden?", "expect": {"nonempty": true, "rubric": "Responde sobre horarios de atención de forma concreta o deriva si no lo sabe. No inventa un horario contradictorio."}}]}
{"id": "handoff-dev", "split": "dev", "tags": ["handoff"], "description": "Pide hablar con una persona.", "turns": [{"user": "quiero hablar con un agente humano por favor", "expect": {"tools_any": ["request_human_assistance"], "rubric": "El bot deriva a un humano / avisa que un agente lo contactará. No insiste en seguir solo."}}]}
{"id": "knowledge-grounded-dev", "split": "dev", "tags": ["knowledge", "rag"], "description": "Pregunta de requisitos: respuesta debe ser concreta, no inventada.", "turns": [{"user": "¿qué necesito para alquilar? ¿qué tipo de garantía aceptan?", "expect": {"tools_any": ["get_faq_answer"], "nonempty": true, "rubric": "Responde con información concreta sobre requisitos y tipos de garantía (propietaria, recibo de sueldo). No inventa políticas que no existen. Usa la herramienta get_faq_answer."}}]}
{"id": "knowledge-oos-dev", "split": "dev", "tags": ["knowledge", "rag", "anti-hallucination"], "description": "Pregunta fuera del corpus de conocimiento: deferral seguro.", "turns": [{"user": "¿tienen propiedades frente al mar en Mar del Plata?", "expect": {"nonempty": true, "tools_none": ["search_properties"], "rubric": "El bot aclara que solo opera en Oberá o que no tiene esa información. No inventa propiedades en Mar del Plata ni afirma que sí tiene opciones allá."}}]}
