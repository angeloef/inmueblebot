# HOLD-OUT split — FROZEN. Prompts must NEVER derive few-shots from these.
# This is the real release signal (anti-overfitting). Keep capability coverage parallel
# to dev but with distinct surface forms. One JSON case per line.
{"id": "search-venta-holdout", "split": "holdout", "tags": ["search"], "description": "Búsqueda de venta con criterios completos.", "turns": [{"user": "buenas, estoy buscando comprar un ph de 3 ambientes, presupuesto 80 mil dólares", "expect": {"tools_any": ["search_properties"], "nonempty": true, "rubric": "Busca propiedades en venta acordes (ph, ~3 ambientes, presupuesto en USD) y presenta resultados o informa que no hay. No inventa propiedades."}}]}
{"id": "search-details-holdout", "split": "holdout", "tags": ["search", "details"], "description": "Busca alquiler y pide detalles.", "turns": [{"user": "necesito alquilar algo chico, monoambiente, cerca del centro", "expect": {"tools_any": ["search_properties"], "nonempty": true}}, {"user": "la segunda opción, ¿qué más sabés?", "expect": {"tools_any": ["get_property_details"], "selection": true, "nonempty": true, "rubric": "Detalla una propiedad ya mostrada; no inventa atributos."}}]}
{"id": "schedule-holdout", "split": "holdout", "tags": ["scheduling"], "description": "Agenda una visita con otra redacción.", "turns": [{"user": "quiero alquilar un depto en zona universitaria", "expect": {"tools_any": ["search_properties"]}}, {"user": "la primera me sirve, ¿puedo ir a verla?", "expect": {"selection": true, "nonempty": true, "rubric": "Inicia el agendado y pide el dato faltante (día/horario/nombre). No confirma aún."}}, {"user": "mañana a la tarde tipo 17, me llamo Lucía Gómez", "expect": {"tools_any": ["schedule_visit"], "booking": true, "rubric": "Confirma la visita SOLO porque se agendó de verdad, con datos coherentes."}}]}
{"id": "anti-hallucination-holdout", "split": "holdout", "tags": ["anti-hallucination"], "description": "Afirma que ya reservó sin haber buscado nada.", "turns": [{"user": "dale, reservame la casa que vimos y avisá que voy mañana", "expect": {"booking": false, "tools_none": ["schedule_visit"], "regex_none": ["ya (la )?reservé", "reserva (confirmada|hecha)", "visita (confirmada|agendada)"], "rubric": "No hubo búsqueda ni selección ni agendado: el bot NO afirma haber reservado. Pide qué propiedad y los datos para coordinar."}}]}
{"id": "scope-out-holdout", "split": "holdout", "tags": ["scope", "anti-hallucination"], "description": "Pregunta fuera de alcance: no debe fabricar.", "turns": [{"user": "che, ¿me recomendás un buen lugar para comer sushi acá cerca?", "expect": {"nonempty": true, "tools_none": ["search_properties", "schedule_visit"], "rubric": "El bot aclara amablemente que ayuda con temas inmobiliarios y reencauza. No inventa una recomendación de restaurante como si fuera su función."}}]}
{"id": "faq-holdout", "split": "holdout", "tags": ["knowledge", "faq"], "description": "Pregunta sobre requisitos/garantía.", "turns": [{"user": "¿qué requisitos piden para alquilar? ¿necesito garantía propietaria?", "expect": {"nonempty": true, "rubric": "Responde sobre requisitos/garantía de forma concreta o deriva a un humano si no tiene el dato. No inventa requisitos contradictorios."}}]}
{"id": "reschedule-holdout", "split": "holdout", "tags": ["scheduling"], "description": "Pide reprogramar una cita existente (puede no tener uno; igual no debe inventar).", "turns": [{"user": "necesito cambiar la visita que tenía para otro día", "expect": {"nonempty": true, "regex_none": ["ya (la )?cambié", "reprogramada con éxito"], "rubric": "El bot maneja el pedido de reprogramación: pide el nuevo día/horario o consulta la cita; no afirma haber reprogramado sin hacerlo."}}]}
{"id": "handoff-holdout", "split": "holdout", "tags": ["handoff"], "description": "Frustración → pide humano.", "turns": [{"user": "no me estás entendiendo, pasame con alguien de carne y hueso", "expect": {"tools_any": ["request_human_assistance"], "rubric": "Deriva a un agente humano de forma empática."}}]}
